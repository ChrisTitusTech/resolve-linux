#!/usr/bin/env bash
set -Eeuo pipefail

# fix-fedora-resolve
# Fixes DaVinci Resolve on current Fedora when Resolve's bundled old GLib stack
# conflicts with Fedora's system Pango/GLib libraries.
#
# Main fix:
#   Move Resolve's bundled libglib/libgio/libgobject/libgmodule/libgthread
#   out of /opt/resolve/libs so Resolve uses Fedora's system GLib stack.
#
# Usage:
#   fix-fedora-resolve
#   fix-fedora-resolve --launch
#   fix-fedora-resolve --dry-run
#   fix-fedora-resolve --restore
#   fix-fedora-resolve --check-only
#   fix-fedora-resolve --fix-system

FEDORA_MULTIMEDIA_PACKAGES=(
  ffmpeg
  ffmpeg-libs
  gstreamer1-plugin-libav
  gstreamer1-plugins-bad-free
  gstreamer1-plugins-bad-free-extras
  gstreamer1-plugins-bad-freeworld
  gstreamer1-plugins-good
  gstreamer1-plugins-good-extras
  gstreamer1-plugins-ugly
  intel-media-driver
  libva-utils
  mesa-va-drivers-freeworld
)

GSTREAMER_REQUIRED_ELEMENTS=(
  qtdemux
  h264parse
  avdec_h264
  opusdec
)

RESOLVE_ROOT="/opt/resolve"
RESOLVE_LIBS="$RESOLVE_ROOT/libs"
RESOLVE_BIN="$RESOLVE_ROOT/bin/resolve"
DISABLED_ROOT="$RESOLVE_LIBS/disabled-libraries"
STAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_DIR="$DISABLED_ROOT/fix-fedora-resolve-$STAMP"

DRY_RUN=0
LAUNCH=0
RESTORE=0
CHECK_ONLY=0
FIX_SYSTEM=0

log() {
  printf '[fix-fedora-resolve] %s\n' "$*"
}

warn() {
  printf '[fix-fedora-resolve] WARNING: %s\n' "$*" >&2
}

die() {
  printf '[fix-fedora-resolve] ERROR: %s\n' "$*" >&2
  exit 1
}

run() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf '[dry-run] '
    printf '%q ' "$@"
    printf '\n'
  else
    "$@"
  fi
}

usage() {
  cat <<USAGE
Usage:
  fix-fedora-resolve [options]

Options:
  --dry-run       Show what would be changed, but do not move files
  --launch        Launch DaVinci Resolve after applying the fix
  --restore       Restore the newest fix-fedora-resolve backup
  --check-only    Only show diagnostics; do not change anything
  --fix-system    If Fedora GLib/Pango look broken, run dnf refresh/reinstall
  -h, --help      Show this help

What this script does:
  1. Checks Fedora glib2/pango package versions.
  2. Verifies /lib64/libglib-2.0.so.0 exports g_once_init_leave_pointer.
  3. Checks Fedora FFmpeg/GStreamer video encode/decode support.
  4. Installs known missing Fedora multimedia dependency packages.
  5. Checks Resolve for missing host shared-library dependencies.
  6. Installs known missing Fedora dependency packages before changing Resolve.
  7. Finds Resolve-bundled old GLib-family libraries.
  8. Moves them to:
       /opt/resolve/libs/disabled-libraries/fix-fedora-resolve-<timestamp>/
  9. Runs ldconfig.
  10. Optionally launches /opt/resolve/bin/resolve.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      ;;
    --launch)
      LAUNCH=1
      ;;
    --restore)
      RESTORE=1
      ;;
    --check-only)
      CHECK_ONLY=1
      ;;
    --fix-system)
      FIX_SYSTEM=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown option: $1"
      ;;
  esac
  shift
done

need_path() {
  [[ -e "$1" ]] || die "Missing required path: $1"
}

sudo_cmd() {
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    "$@"
  else
    sudo "$@"
  fi
}

sudo_run() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
      printf '[dry-run] '
      printf '%q ' "$@"
      printf '\n'
    else
      printf '[dry-run] sudo '
      printf '%q ' "$@"
      printf '\n'
    fi
  else
    sudo_cmd "$@"
  fi
}

print_system_info() {
  log "System package check:"
  if command -v rpm >/dev/null 2>&1; then
    rpm -q glib2 pango || true
  else
    warn "rpm not found; cannot query Fedora packages."
  fi

  log "System GLib symbol check:"
  if [[ -e /lib64/libglib-2.0.so.0 ]]; then
    if command -v objdump >/dev/null 2>&1; then
      if objdump -T /lib64/libglib-2.0.so.0 | awk '$NF == "g_once_init_leave_pointer" {found = 1} END {exit !found}'; then
        log "OK: /lib64/libglib-2.0.so.0 exports g_once_init_leave_pointer"
      else
        warn "BAD: /lib64/libglib-2.0.so.0 does not export g_once_init_leave_pointer"
        warn "Your Fedora glib2/pango packages may be mismatched or broken."
        return 2
      fi
    else
      warn "objdump not found; install binutils if you want symbol verification."
    fi
  else
    warn "Missing /lib64/libglib-2.0.so.0"
    return 2
  fi

  return 0
}

fix_system_packages() {
  if [[ "$FIX_SYSTEM" -ne 1 ]]; then
    warn "System GLib check failed. Re-run with --fix-system to refresh/reinstall glib2 and pango."
    return 0
  fi

  command -v dnf >/dev/null 2>&1 || die "dnf not found; cannot fix system packages."

  log "Refreshing and reinstalling Fedora glib2/pango packages..."
  sudo_run dnf upgrade --refresh -y glib2 pango
  sudo_run dnf reinstall -y glib2 pango
  sudo_run ldconfig

  log "Rechecking system GLib symbol..."
  print_system_info || die "System GLib still does not look correct after package repair."
}

show_multimedia_info() {
  log "Fedora multimedia package check:"

  local missing=0

  if ! command -v rpm >/dev/null 2>&1; then
    warn "rpm not found; cannot query Fedora multimedia packages."
  else
    local package
    for package in "${FEDORA_MULTIMEDIA_PACKAGES[@]}"; do
      if rpm -q "$package"; then
        :
      else
        missing=1
      fi
    done
  fi

  log "GStreamer decode element check:"
  if ! command -v gst-inspect-1.0 >/dev/null 2>&1; then
    warn "gst-inspect-1.0 not found; install gstreamer1 if desktop video playback is broken."
    return 1
  fi

  local element
  for element in "${GSTREAMER_REQUIRED_ELEMENTS[@]}"; do
    if gst-inspect-1.0 "$element" >/dev/null 2>&1; then
      log "OK: GStreamer element available: $element"
    else
      warn "Missing GStreamer element: $element"
      missing=1
    fi
  done

  return "$missing"
}

install_fedora_multimedia_deps() {
  command -v dnf >/dev/null 2>&1 || die "dnf not found; cannot install Fedora multimedia dependencies."

  local missing_packages=()
  local package

  for package in "${FEDORA_MULTIMEDIA_PACKAGES[@]}"; do
    if ! rpm -q "$package" >/dev/null 2>&1; then
      missing_packages+=("$package")
    fi
  done

  if [[ "${#missing_packages[@]}" -eq 0 ]]; then
    log "Fedora multimedia package set is already installed."
  else
    log "Installing missing Fedora multimedia encode/decode packages..."
    sudo_run dnf install -y "${missing_packages[@]}"
    sudo_run ldconfig
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    return 0
  fi

  log "Rechecking Fedora multimedia support..."
  show_multimedia_info || die "Fedora multimedia support is still incomplete after package installation."
}

find_missing_resolve_libs() {
  LC_ALL=C ldd "$RESOLVE_BIN" 2>/dev/null | awk '/=> not found/ {print $1}' | sort -u
}

fedora_package_for_lib() {
  case "$1" in
    libGLU.so.1)
      printf '%s\n' "mesa-libGLU"
      return 0
      ;;
    libcrypt.so.1)
      printf '%s\n' "libxcrypt-compat"
      return 0
      ;;
  esac

  if command -v dnf >/dev/null 2>&1; then
    dnf repoquery --quiet --whatprovides "*/$1" --queryformat '%{name} %{arch}' 2>/dev/null \
      | awk '$2 == "x86_64" && found == "" {package = $1; found = 1} END {if (found) {print package} else {exit 1}}'
    return $?
  fi

  return 1
}

resolve_missing_dependency_packages() {
  local missing_libs
  missing_libs="$(find_missing_resolve_libs || true)"

  [[ -n "$missing_libs" ]] || return 0

  local lib package
  while IFS= read -r lib; do
    [[ -n "$lib" ]] || continue
    package="$(fedora_package_for_lib "$lib")"
    [[ -n "$package" ]] || continue
    printf '%s\n' "$package"
  done <<< "$missing_libs" | sort -u
}

show_resolve_host_deps() {
  need_path "$RESOLVE_BIN"

  log "Resolve host dependency check:"

  local missing_libs
  missing_libs="$(find_missing_resolve_libs || true)"

  if [[ -z "$missing_libs" ]]; then
    log "OK: no missing shared libraries reported by ldd."
    return 0
  fi

  warn "Resolve is missing host shared libraries:"
  printf '%s\n' "$missing_libs" >&2

  local packages
  packages="$(resolve_missing_dependency_packages || true)"

  if [[ -n "$packages" ]]; then
    warn "Known Fedora packages needed:"
    printf '%s\n' "$packages" >&2
  fi

  return 1
}

install_resolve_host_deps() {
  local missing_libs
  missing_libs="$(find_missing_resolve_libs || true)"

  [[ -n "$missing_libs" ]] || return 0

  local packages unknown_libs lib package
  packages=""
  unknown_libs=""

  while IFS= read -r lib; do
    [[ -n "$lib" ]] || continue

    package="$(fedora_package_for_lib "$lib")"
    if [[ -n "$package" ]]; then
      packages="${packages}${package}"$'\n'
    else
      unknown_libs="${unknown_libs}${lib}"$'\n'
    fi
  done <<< "$missing_libs"

  if [[ -n "$unknown_libs" ]]; then
    warn "Resolve has missing libraries with no package mapping in this script:"
    printf '%s' "$unknown_libs" >&2
    die "Install those dependencies manually or update the script mapping before moving Resolve libraries."
  fi

  packages="$(printf '%s' "$packages" | sort -u)"
  [[ -n "$packages" ]] || return 0

  command -v dnf >/dev/null 2>&1 || die "dnf not found; cannot install missing Resolve host dependencies."

  log "Installing missing Fedora packages required by Resolve..."
  while IFS= read -r package; do
    [[ -n "$package" ]] || continue
    sudo_run dnf install -y "$package"
  done <<< "$packages"

  sudo_run ldconfig

  if [[ "$DRY_RUN" -eq 1 ]]; then
    return 0
  fi

  log "Rechecking Resolve host dependencies..."
  show_resolve_host_deps || die "Resolve still has missing host dependencies after package installation."
}

find_resolve_glib_libs() {
  find "$RESOLVE_LIBS" -maxdepth 1 \
    \( -type f -o -type l \) \
    \( -name 'libglib-2.0.so*' \
    -o -name 'libgio-2.0.so*' \
    -o -name 'libgobject-2.0.so*' \
    -o -name 'libgmodule-2.0.so*' \
    -o -name 'libgthread-2.0.so*' \) \
    -print | sort
}

show_resolve_libs() {
  log "Resolve-bundled GLib-family libraries currently in $RESOLVE_LIBS:"
  local libs
  libs="$(find_resolve_glib_libs || true)"

  if [[ -z "$libs" ]]; then
    log "None found. Resolve should already be using Fedora's system GLib stack."
  else
    printf '%s\n' "$libs"
  fi
}

apply_fix() {
  need_path "$RESOLVE_ROOT"
  need_path "$RESOLVE_LIBS"
  need_path "$RESOLVE_BIN"

  local libs
  libs="$(find_resolve_glib_libs || true)"

  if [[ -z "$libs" ]]; then
    log "No Resolve-bundled GLib-family libraries found in active library path."
    return 0
  fi

  log "Moving Resolve-bundled GLib-family libraries out of the active loader path..."
  sudo_run mkdir -p "$BACKUP_DIR"

  while IFS= read -r lib; do
    [[ -n "$lib" ]] || continue
    sudo_run mv -v "$lib" "$BACKUP_DIR/"
  done <<< "$libs"

  sudo_run ldconfig

  log "Moved libraries to:"
  log "$BACKUP_DIR"

  log "Post-fix verification:"
  show_resolve_libs
}

restore_latest() {
  need_path "$DISABLED_ROOT"

  local latest
  latest="$(find "$DISABLED_ROOT" -maxdepth 1 -type d -name 'fix-fedora-resolve-*' -printf '%T@ %p\n' 2>/dev/null | sort -nr | awk 'NR==1 {print $2}')"

  [[ -n "${latest:-}" ]] || die "No fix-fedora-resolve backup directory found under $DISABLED_ROOT"

  log "Restoring newest backup:"
  log "$latest"

  local files
  files="$(find "$latest" -maxdepth 1 \( -type f -o -type l \) -print | sort || true)"
  [[ -n "$files" ]] || die "Backup directory is empty: $latest"

  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    sudo_run mv -v "$file" "$RESOLVE_LIBS/"
  done <<< "$files"

  sudo_run ldconfig
  log "Restore complete."
}

launch_resolve() {
  need_path "$RESOLVE_BIN"

  log "Launching DaVinci Resolve as current user..."
  exec "$RESOLVE_BIN"
}

main() {
  need_path "$RESOLVE_ROOT"
  need_path "$RESOLVE_LIBS"

  if [[ "$RESTORE" -eq 1 ]]; then
    restore_latest
    exit 0
  fi

  local system_check_rc=0
  print_system_info || system_check_rc=$?

  if [[ "$system_check_rc" -ne 0 ]]; then
    fix_system_packages
  fi

  local multimedia_deps_rc=0
  show_multimedia_info || multimedia_deps_rc=$?

  local missing_deps_rc=0
  show_resolve_host_deps || missing_deps_rc=$?

  show_resolve_libs

  if [[ "$CHECK_ONLY" -eq 1 ]]; then
    log "Check-only mode complete. No changes made."
    exit 0
  fi

  if [[ "$multimedia_deps_rc" -ne 0 ]]; then
    install_fedora_multimedia_deps
  fi

  if [[ "$missing_deps_rc" -ne 0 ]]; then
    install_resolve_host_deps
  fi

  apply_fix

  if [[ "$LAUNCH" -eq 1 ]]; then
    launch_resolve
  fi

  log "Done. Test with:"
  log "  /opt/resolve/bin/resolve"
}

main "$@"
